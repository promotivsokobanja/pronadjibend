// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  role            String // "ADMIN", "BAND", "CLIENT"
  plan            String           @default("BASIC")
  planUntil       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  band            Band?            @relation(fields: [bandId], references: [id])
  bandId          String?          @unique
  musicianProfile MusicianProfile?
  messages        Message[]
}

model Band {
  id                 String           @id @default(cuid())
  name               String
  genre              String
  location           String
  priceRange         String?
  bio                String?
  videoUrl           String?
  audioUrl           String?
  hasEquipment       Boolean          @default(false)
  rider              String? // Technical requirements
  qrToken            String?          @unique // For active session
  rating             Float            @default(0)
  img                String?
  isPaid             Boolean          @default(false)
  plan               String           @default("FREE")
  /// Gost na live stranici vidi korak bakšiša uz narudžbinu pesme + „Časti bend”
  allowTips          Boolean          @default(true)
  /// Maksimalan broj live zahteva koji mogu biti na čekanju (PENDING). 0 = bez limita.
  maxPendingRequests Int              @default(10)
  /// Da li se repertoar benda prikazuje javno na profilu (za pretragu)
  showRepertoire     Boolean          @default(false)
  /// Kada je uključeno, gosti mogu da naruče bilo koju pesmu iz repertoara tokom live režima (ne samo one iz aktivnih set listi)
  allowFullRepertoireLive Boolean     @default(false)
  songs              Song[] // Repertoire
  bookings           Booking[]
  liveRequests       LiveRequest[]
  reviews            Review[]
  busyDates          BusyDate[]
  musicianInvites    MusicianInvite[]  // invites where this band is involved
  user               User?
  deletedAt          DateTime?
  MidiFile           MidiFile[]
  setLists           SetList[]
}

model Song {
  id                String           @id @default(cuid())
  title             String
  artist            String
  lyrics            String?
  chords            String? // Chords with transposition marks
  key               String? // Original key
  category          String? // e.g., "Muške Zabavne"
  type              String? // e.g., "Zabavna", "Narodna"
  band              Band?            @relation(fields: [bandId], references: [id])
  bandId            String?
  musicianProfile   MusicianProfile? @relation(fields: [musicianProfileId], references: [id])
  musicianProfileId String?
  liveRequests      LiveRequest[]
  setListItems      SetListItem[]
}

model SongSubmission {
  id                    String    @id @default(cuid())
  title                 String
  artist                String
  lyrics                String?
  chords                String?
  key                   String?
  category              String?
  type                  String?
  status                String    @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "DUPLICATE"
  sourceSongId          String?
  submittedByBandId     String?
  submittedByMusicianId String?
  reviewedByUserId      String?
  approvedSongId        String?
  rejectReason          String?
  reviewedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([submittedByBandId, createdAt])
  @@index([submittedByMusicianId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  author    String
  createdAt DateTime @default(now())
  band      Band     @relation(fields: [bandId], references: [id])
  bandId    String
}

model BusyDate {
  id     String   @id @default(cuid())
  date   DateTime
  reason String?
  band   Band     @relation(fields: [bandId], references: [id])
  bandId String
}

model Booking {
  id          String   @id @default(cuid())
  clientName  String
  clientEmail String
  clientPhone String?
  date        DateTime
  status      String   @default("PENDING") // "PENDING", "BAND_ACCEPTED", "CONFIRMED", "CANCELLED", "COMPLETED"
  message     String?
  location    String?
  price       String?
  band        Band     @relation(fields: [bandId], references: [id])
  bandId      String
  createdAt   DateTime @default(now())
}

model LiveRequest {
  id                String           @id @default(cuid())
  tableNum          String
  status            String           @default("PENDING") // "PENDING", "PLAYED", "REJECTED", "ACCEPTED"
  createdAt         DateTime         @default(now())
  /// SONG = zahtev za pesmu; WAITER_TIP = bakšiš preko konobara (songId opciono)
  requestType       String           @default("SONG")
  /// Za WAITER_TIP: tekst za bend, npr. „Sto 3 šalje bakšiš preko konobara (500 RSD)”
  guestNote         String?
  /// Bakšiš preko konobara uz pesmu (RSD); null = bez bakšiša
  tipAmountRsd      Int?
  song              Song?            @relation(fields: [songId], references: [id])
  songId            String?
  band              Band?            @relation(fields: [bandId], references: [id])
  bandId            String?
  musician          MusicianProfile? @relation(fields: [musicianProfileId], references: [id])
  musicianProfileId String?
}

model MidiFile {
  id                String           @id @default(cuid())
  title             String
  artist            String
  category          String // "Zabavna", "Narodna", "Kola", "Mixevi", "Decije"
  fileName          String
  filePath          String // Path in Supabase storage
  fileSize          Int              @default(0)
  fileType          String           @default("midi") // "midi" | "audio"
  uploadedBy        String? // userId of uploader (for user MP3 uploads)
  band              Band?            @relation(fields: [bandId], references: [id])
  bandId            String?
  musician          MusicianProfile? @relation(fields: [musicianProfileId], references: [id])
  musicianProfileId String?
  createdAt         DateTime         @default(now())

  @@index([category])
  @@index([title])
  @@index([artist])
  @@index([fileType])
}

model BillingEvent {
  id                 String   @id @default(cuid())
  stripeSessionId    String?  @unique
  stripeCustomerId   String?
  stripeSubscription String?
  customerEmail      String?
  status             String
  createdAt          DateTime @default(now())
}

model MusicianProfile {
  id                String                 @id @default(cuid())
  user              User?                  @relation(fields: [userId], references: [id])
  userId            String?                @unique
  name              String
  primaryInstrument String
  genres            String?
  city              String
  priceFromEur      Int?
  priceToEur        Int?
  experienceYears   Int?
  bio               String?
  img               String?
  videoUrl          String?
  rating            Float                  @default(0)
  isFeatured        Boolean                @default(false)
  isAvailable       Boolean                @default(true)
  allowTips         Boolean                @default(true)
  /// Da li se repertoar muzičara prikazuje javno na profilu (za pretragu)
  showRepertoire     Boolean                @default(false)
  /// Kada je uključeno, gosti mogu da naruče bilo koju pesmu iz repertoara tokom live režima (ne samo one iz aktivnih set listi)
  allowFullRepertoireLive Boolean           @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  availabilities    MusicianAvailability[]
  receivedInvites    MusicianInvite[] @relation("receivedInvites")
  sentInvites        MusicianInvite[] @relation("sentInvites")
  songs             Song[]
  liveRequests      LiveRequest[]
  midiFiles         MidiFile[]
  setLists          SetList[]
  deletedAt         DateTime?

  @@index([city])
  @@index([primaryInstrument])
  @@index([isAvailable, isFeatured])
}

model MusicianAvailability {
  id          String          @id @default(cuid())
  date        DateTime
  isAvailable Boolean         @default(true)
  note        String?
  musician    MusicianProfile @relation(fields: [musicianId], references: [id])
  musicianId  String

  @@index([musicianId, date])
}

model MusicianInvite {
  id               String           @id @default(cuid())
  status           String           @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED", "CANCELLED"
  senderType       String           @default("BAND")    // "BAND" or "MUSICIAN"
  eventDate        DateTime?
  location         String?
  feeEur           Int?
  message          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  band             Band?            @relation(fields: [bandId], references: [id])
  bandId           String?
  musician         MusicianProfile  @relation("receivedInvites", fields: [musicianId], references: [id])
  musicianId       String
  senderMusician   MusicianProfile? @relation("sentInvites", fields: [senderMusicianId], references: [id])
  senderMusicianId String?
  messages         Message[]

  @@index([bandId, createdAt])
  @@index([musicianId, createdAt])
  @@index([senderMusicianId, createdAt])
  @@index([status])
}

model Message {
  id        String         @id @default(cuid())
  body      String
  invite    MusicianInvite @relation(fields: [inviteId], references: [id])
  inviteId  String
  sender    User           @relation(fields: [senderId], references: [id])
  senderId  String
  createdAt DateTime       @default(now())

  @@index([inviteId, createdAt])
}

model SetList {
  id                String           @id @default(cuid())
  name              String
  isLive            Boolean          @default(false)
  band              Band?            @relation(fields: [bandId], references: [id])
  bandId            String?
  musicianProfile   MusicianProfile? @relation(fields: [musicianProfileId], references: [id])
  musicianProfileId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  items             SetListItem[]

  @@index([bandId])
  @@index([musicianProfileId])
}

model SetListItem {
  id        String  @id @default(cuid())
  position  Int     @default(0)
  setList   SetList @relation(fields: [setListId], references: [id], onDelete: Cascade)
  setListId String
  song      Song    @relation(fields: [songId], references: [id])
  songId    String

  @@index([setListId])
  @@index([songId])
}

/// Jedan zapis (id = 1): javna podešavanja (admin /sistem)
model SiteConfig {
  id                   Int      @id @default(1)
  showDemoBands        Boolean  @default(true)
  bandProfileMaxImages Int      @default(5)
  bandProfileMaxVideos Int      @default(3)
  bandProfileMaxLinks  Int      @default(5)
  maintenanceMode      Boolean  @default(false)
  korgPaDriveUrl       String?
  korgPaItemsJson      String?
  updatedAt            DateTime @updatedAt
}
