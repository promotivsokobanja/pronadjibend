{
  "name": "pronadjibend-web",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://pronadjibend.rs",
  "scripts": {
    "postinstall": "prisma generate",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache','node_modules/.next','.turbo'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "prisma generate && cross-env NEXT_PRIVATE_BUILD_WORKER_COUNT=1 next build",
    "build:clean": "npm run clean && npm run build",
    "build:next": "next build",
    "db:migrate": "prisma migrate deploy",
    "start": "next start",
    "lint": "next lint",
    "create-admin": "node scripts/create-admin.cjs",
    "poster": "node scripts/generate-marketing-poster.cjs",
    "check:release": "npm run lint && npm run build",
    "deploy:push": "powershell -ExecutionPolicy Bypass -File scripts/push-deploy.ps1",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tonejs/midi": "^2.0.28",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.330.0",
    "midi-file": "^1.2.4",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.3",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "soundfont-player": "^0.12.0",
    "stripe": "^21.0.1",
    "tone": "^15.1.22",
    "prisma": "^5.10.2"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
