# Kopiraj u .env.local (vrednosti preuzmi iz starog antigravity/.env.local).
#
# LOKALNO:
#   docker compose up -d
#   npx prisma migrate deploy
#   npm run dev
#
# Javni kanonski URL (SEO, sitemap, OG). Na Netlify može ostati prazno — koristi se URL iz okruženja.
# NEXT_PUBLIC_SITE_URL=https://pronadjibend.rs

# Google Search Console (meta verification). Ostavi prazno dok nemaš token.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# PostgreSQL (Neon, Supabase, Docker lokalno, …) — ista vrednost u Netlify env
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT za /api/auth/login (kolačić auth-token) — isti ili kompatibilan sa NEXTAUTH_SECRET
JWT_SECRET=replace-with-long-random-secret-min-32-chars

# NextAuth (Google) — produkcija: NEXTAUTH_URL=https://pronadjibend.rs (bez / na kraju)
# U Google Cloud → Credentials → OAuth client → Authorized redirect URIs dodaj:
#   https://pronadjibend.rs/api/auth/callback/google
# Lokalno: http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# true = dugme „Nastavi preko Google” (mora biti u Netlify env pri buildu)
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Više kanonskih domena (login/register iza proxy-ja) — opciono, zarezom
# ALLOWED_AUTH_ORIGINS=https://pronadjibend.rs,https://www.pronadjibend.rs

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Media upload provider (supabase | cloudinary)
MEDIA_UPLOAD_PROVIDER=supabase

# Supabase (required for provider=supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional custom bucket names (default: band-images / band-videos)
# SUPABASE_MEDIA_IMAGES_BUCKET=band-images
# SUPABASE_MEDIA_VIDEOS_BUCKET=band-videos

# Optional FFmpeg video transcode before upload (best effort)
# MEDIA_VIDEO_TRANSCODE_ENABLED=true
# MEDIA_VIDEO_TRANSCODE_STRICT=false
# MEDIA_VIDEO_MAX_WIDTH=1280
# MEDIA_VIDEO_MAX_HEIGHT=720
# MEDIA_VIDEO_CRF=28
# MEDIA_VIDEO_PRESET=veryfast
# FFMPEG_PATH=ffmpeg

# Cloudinary (required for provider=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# node scripts/create-admin.cjs
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=...

# ── Obaveštenje bendu o novom upitu (POST /api/bookings) ──
# Bez ovoga upit i dalje ostaje u bazi; mejl se ne šalje.
# Iste vrednosti dodaj u Netlify → Site configuration → Environment variables.
#
# SMTP_HOST=smtp.tvoj-provajder.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# SMTP_SECURE=false
# SMTP_FROM="Pronađi Bend <office@pronadjibend.rs>"
# (ili BOOKING_EMAIL_FROM=...)
#
# Za 465 (SSL): SMTP_PORT=465 i SMTP_SECURE=true
